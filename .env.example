# ── Required ─────────────────────────────────────────────────────────────────

# The public domain pointing to your VPS (must have an A record)
NETBIRD_DOMAIN=netbird.your-domain.com

# TURN server shared secret (generate with: openssl rand -hex 32)
TURN_SECRET=change_me_generate_with_openssl_rand_hex_32

# ── Optional ──────────────────────────────────────────────────────────────────

# Auth audience if you plug in an external IdP (leave as-is for simple setup)
NETBIRD_AUTH_AUDIENCE=netbird
